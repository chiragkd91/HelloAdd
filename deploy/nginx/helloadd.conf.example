# Hello Add — Nginx (SSL only, same pattern as multi-sites.conf)
#
# Production domain: helloadd.online (paste into multi-sites.conf or sites-enabled as needed)
#
# Issue one cert for all names:
#   sudo certbot certonly --nginx -d helloadd.online -d www.helloadd.online -d app.helloadd.online
#
# PM2: marketing web 127.0.0.1:30002, dashboard 127.0.0.1:3001
# Set NEXT_PUBLIC_MARKETING_URL / NEXT_PUBLIC_DASHBOARD_URL to these https URLs.
#
#   sudo nginx -t && sudo systemctl reload nginx

##############################################
# HELLO ADD — marketing site (apps/web)
##############################################

server {
    listen 80;
    server_name helloadd.online www.helloadd.online;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name helloadd.online www.helloadd.online;

    ssl_certificate /etc/letsencrypt/live/helloadd.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/helloadd.online/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    client_max_body_size 25m;

    location / {
        proxy_pass http://127.0.0.1:30002;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 86400;
    }
}

##############################################
# HELLO ADD — dashboard (apps/dashboard)
##############################################

server {
    listen 80;
    server_name app.helloadd.online;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name app.helloadd.online;

    ssl_certificate /etc/letsencrypt/live/helloadd.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/helloadd.online/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    client_max_body_size 25m;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout 86400;
    }
}
