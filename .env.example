# Demo seed (from repo root: npm run db:seed — or npm run db:seed:demo-year to wipe & rebuild ~1 year of metrics)
# SEED_DEMO_YEAR=1
# SEED_METRICS_DAYS=365

# MongoDB connection string (used by Mongoose in @helloadd/database).
# Optional: if omitted, the app defaults to mongodb://127.0.0.1:27017/helloadd (local MongoDB).
# Use database name `helloadd` in the path (same as `npm run db:ensure`). Example with auth:
# MONGODB_URI="mongodb://user:pass@host:27017/helloadd?authSource=admin"
MONGODB_URI="mongodb://127.0.0.1:27017/helloadd"

# Marketing site (apps/web): http://localhost:30002 — landing page, pricing, /login for the public app.
# Dashboard (apps/dashboard): http://localhost:3001 — CMO app after sign-in.
# To use a different port, change apps/web/package.json dev script (-p <port>).
# NEXT_PUBLIC_APP_URL=http://localhost:30002
#
# apps/web: /register POSTs to the dashboard API; session cookie is set on the dashboard origin.
# NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
#
# Dashboard: show “Visit public site” link on login (optional override).
# NEXT_PUBLIC_MARKETING_URL=http://localhost:30002

# Copy to apps/dashboard/.env.local for API routes (Part 7)
# Auth: POST /api/auth/login sets httpOnly cookie "session" + returns { token }.
# Call protected routes with: Authorization: Bearer <token> and optional x-organization-id: <orgId>

# NextAuth (dashboard) — optional if you add NextAuth later
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3001

# Client portal signed links (agency → client). Set at least one in production / `next start`:
# - CLIENT_PORTAL_SECRET (recommended), or
# - NEXTAUTH_SECRET (shared with NextAuth if you use it).
# `next dev` uses an insecure built-in key if both are unset (see lib/clientPortal/token.ts).
# CLIENT_PORTAL_SECRET=your-long-random-string

# Meta (Facebook) Marketing API — optional; without these, Meta connect uses a local OAuth stub.
# META_APP_ID=
# META_APP_SECRET=

# Google Ads API — OAuth + developer token (optional; without OAuth vars, connect uses stub).
# Create OAuth client in Google Cloud Console; redirect URI: http://localhost:3001/api/integrations/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Developer token from Google Ads API Center (required for Ads API REST calls after OAuth).
# GOOGLE_DEVELOPER_TOKEN=
# Optional: MCC / manager account numeric ID (no dashes) when the API requires login-customer-id.
# GOOGLE_LOGIN_CUSTOMER_ID=

# LinkedIn Marketing API — OAuth (optional; without these, connect uses stub).
# Redirect URL: http://localhost:3001/api/integrations/linkedin/callback
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Hourly sync cron (dashboard Node server only). Not for serverless — use an external job or POST /api/sync.
# ENABLE_SYNC_CRON=true

# OpenAI — chat, scheduler text (content-writer), and DALL·E 3 image generation on Scheduler → Create post.
# Other AI features (reports, budget, campaign analyzer, etc.) still use Anthropic unless migrated separately.
# OPENAI_API_KEY=
# Optional: estimated USD per generated image for usage logs (default ~0.04 for DALL·E 3 standard 1024²).
# OPENAI_IMAGE_COST_USD=0.04
# Optional models (default gpt-4o-mini). OPENAI_MODEL is accepted as an alias for chat/content defaults.
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_CONTENT_MODEL=gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# Text AI backend for chat + scheduler content: openai | anthropic | unset (auto: OpenAI if key exists, else Anthropic)
# AI_CHAT_PROVIDER=
# Optional override for all text AI above (same values); takes precedence over AI_CHAT_PROVIDER when set.
# AI_TEXT_PROVIDER=

# Anthropic Claude — server-side only. Used for budget insights, campaign analysis, PDF summaries, error
# explanations, agency tools, and chat when OpenAI is not configured.
# ANTHROPIC_API_KEY=
# Optional model override:
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
#
# Client: hide floating chat / campaign AI blocks in production builds when false.
# NEXT_PUBLIC_AI_ENABLED=true
#
# Per-plan hourly AI call caps (defaults shown in code if unset).
# AI_RATE_LIMIT_TRIAL=20
# AI_RATE_LIMIT_STARTER=50
# AI_RATE_LIMIT_GROWTH=200
# AI_RATE_LIMIT_AGENCY=1000

# Resend — scheduled & test PDF reports, team invite emails (https://resend.com). Use a verified domain in production.
# RESEND_API_KEY=
# RESEND_FROM="Hello Add <reports@yourdomain.com>"
# Optional override for invite emails (defaults to RESEND_FROM).
# RESEND_INVITES_FROM="Hello Add <invites@yourdomain.com>"

# Weekly/monthly report cron (same constraints as sync cron — long-lived Node process).
# ENABLE_REPORT_CRON=true

# Monday agency digest — logs digest text server-side (email TBD). Long-lived Node only.
# ENABLE_AGENCY_DIGEST_CRON=true

# Absolute dashboard URL for report emails (defaults to NEXTAUTH_URL or localhost:3001).
# NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001

# WhatsApp Cloud API (Meta) — optional global fallback if no org saved Integrations → WhatsApp Business.
# Per-workspace credentials: Integrations page (Phone Number ID + permanent token). Alerts use org integration first.
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_TOKEN=

# Daily WARNING digest to WhatsApp (~9:00 IST) on long-lived Node only.
# ENABLE_WHATSAPP_DIGEST_CRON=true

# Razorpay subscriptions (dashboard billing). Webhook URL: https://<your-domain>/api/billing/webhook
# RAZORPAY_KEY_ID=rzp_live_xxx
# RAZORPAY_KEY_SECRET=xxx
# RAZORPAY_WEBHOOK_SECRET=xxx
# RAZORPAY_PLAN_STARTER=plan_xxx
# RAZORPAY_PLAN_GROWTH=plan_xxx
# RAZORPAY_PLAN_AGENCY=plan_xxx
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx

